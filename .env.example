# ============================================
# Supabase Configuration
# Get from: https://supabase.io
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_project_id_here

# Backend only (keep secret, not in frontend)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_SECRET_KEY=your_secret_key_here

# ============================================
# OAuth & API Configuration
# Copy this file to .env.local and fill in actual values
# DO NOT COMMIT .env.local to version control

# ============================================
# Google OAuth Credentials
# Get from: https://console.cloud.google.com
# ============================================
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============================================
# Apple Sign-In Credentials
# Get from: https://developer.apple.com/account
# ============================================
VITE_APPLE_TEAM_ID=your_apple_team_id
VITE_APPLE_SERVICE_ID=com.housecom.service
VITE_APPLE_KEY_ID=your_key_id_from_apple
VITE_APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n[your private key content]\n-----END PRIVATE KEY-----

# ============================================
# Optional: Production Configuration
# ============================================
VITE_PRODUCTION_DOMAIN=yourdomain.com
VITE_API_BASE_URL=https://api.yourdomain.com/api
